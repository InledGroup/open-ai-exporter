{
  "manifest_version": 3,
  "name": "AI Exporter",
  "version": "1.0.5",
  "description": "Export chats from ChatGPT, Claude, Gemini, Perplexity, Kimi y DeepSeek to PDF, MD, TXT, JSON and WORD.",
  "icons": {
    "16": "aiexporter.png",
    "48": "aiexporter.png",
    "128": "aiexporter.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://aistudio.google.com/*",
        "*://notebooklm.google.com/*",
        "*://*.perplexity.ai/*",
        "*://*.kimi.com/*",
        "*://kimi.com/*",
        "*://kimi.moonshot.cn/*",
        "*://chat.deepseek.com/*",
        "*://*.deepseek.com/*"
      ],
      "js": ["loader.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*",
    "*://aistudio.google.com/*",
    "*://notebooklm.google.com/*",
    "*://*.perplexity.ai/*",
    "*://kimi.ai/*",
    "*://kimi.moonshot.cn/*",
    "*://chat.deepseek.com/*",
    "*://*.deepseek.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
